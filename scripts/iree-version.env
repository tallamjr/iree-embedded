# Single source of truth for the pinned IREE version.
# IREE_SHA is the runtime source commit (tag v3.11.0); IREE_PIP_VERSION is the
# matching iree-base-compiler / iree-base-runtime release on PyPI, which
# provides both the host tools the cross-build needs (IREE_HOST_BIN_DIR) and
# the iree-compile that models must be compiled with.
IREE_SHA=e4a3b0405d7d23554da26403658d0e8c3c5ecf25
IREE_PIP_VERSION=3.11.0
